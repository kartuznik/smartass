        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(rag_query_duration_seconds_sum{job=\"bot\"}[5m])) / clamp_min(sum(rate(rag_query_duration_seconds_count{job=\"bot\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "title": "Average Response Time",
      "type": "timeseries"
