# ------------------------------
# Telegram bot
# ------------------------------
# Token from BotFather
TELEGRAM_BOT_TOKEN=

# ------------------------------
# LLM provider switch
# Allowed: openai | deepseek
# GPT-4o-mini is 30-50x cheaper than GPT-4o and recommended for development.
# $0.70 balance is sufficient for thousands of queries.
# ------------------------------
LLM_PROVIDER=openai

# ------------------------------
# OpenAI configuration
# Default endpoint: https://api.openai.com/v1
# ------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------
# OPTIONAL: Requires account balance top-up.
# DeepSeek configuration
# Get API key at: https://platform.deepseek.com
# Default endpoint: https://api.deepseek.com
# ------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ------------------------------
# Model name
# openai default: gpt-4o-mini
# deepseek default: deepseek-chat
# Default for development: gpt-4o-mini
# ------------------------------
MODEL_NAME=gpt-4o-mini
